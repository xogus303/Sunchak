# 이 파일은 "필요한 키 목록·형식" 참고용이다. 실제 비밀값은 Infisical에 저장하고
# `infisical run -- <명령>`으로 주입한다 (ADR 0011). 로컬 .env로 직접 실행도 가능.

# 서버 포트 (프론트 Next.js가 3000을 쓰므로 3001)
PORT=3001

# PostgreSQL 접속 정보 (비밀값 — 실제 값은 git에 올리지 말 것)
# [개발·공유] Neon 클라우드 DB — 두 기기가 같은 URL로 접속해 데이터 공유 (ADR 0010)
#   Neon 대시보드에서 발급한 문자열을 각 기기의 .env 에 붙여넣는다.
#   형식 예: postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/sunchak?sslmode=require
# [W2 부하테스트] 로컬 Postgres — infra/docker-compose.yml 계정과 일치
#   postgresql://sunchak:sunchak@localhost:5432/sunchak?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST/sunchak?sslmode=require"

# Redis 연결 (로컬 — docker-compose)
REDIS_URL="redis://localhost:6379"

# JWT (W1 인증 단계에서 사용)
JWT_SECRET="change-me-in-local"
JWT_EXPIRES_IN="1h"
